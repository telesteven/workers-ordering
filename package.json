{
  "name": "workers-ordering",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "worker:dev": "wrangler dev",
    "deploy": "npm run build && wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply d1-workers-ordering --local",
    "db:migrate:remote": "wrangler d1 migrations apply d1-workers-ordering --remote",
    "db:seed:local": "wrangler d1 execute d1-workers-ordering --local --file=./seed/seed.sql",
    "db:seed:remote": "wrangler d1 execute d1-workers-ordering --remote --file=./seed/seed.sql",
    "db:prune-tables:local": "wrangler d1 execute d1-workers-ordering --local --file=./scripts/prune-tables-above-6.sql",
    "db:prune-tables:remote": "wrangler d1 execute d1-workers-ordering --remote --file=./scripts/prune-tables-above-6.sql",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "hono": "^4.6.14",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241127.0",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.7.2",
    "vite": "^5.4.11",
    "wrangler": "^4.107.0"
  }
}
